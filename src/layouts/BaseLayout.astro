---
import Seo from "../components/Seo.astro";
import "../styles/global.css";
import { company } from "../data/company";
import { alternateLanguage, labels, localizePath, site, type Language } from "../data/site";

interface Props {
  title: string;
  description: string;
  pathname: string;
  language: Language;
  alternatePath?: string;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const { title, description, pathname, language, alternatePath, jsonLd } = Astro.props;
const copy = labels[language];
const otherLanguage = alternateLanguage(language);
const switchPath = alternatePath || localizePath(otherLanguage);
const alternates = {
  en: pathname.replace(/^\/(en|zh)\//, "/en/"),
  zh: pathname.replace(/^\/(en|zh)\//, "/zh/"),
} as Record<Language, string>;
const currentYear = new Date().getUTCFullYear();
const companyName = language === "zh" ? company.legalNameZh : company.legalNameEn;
const address = language === "zh" ? company.addressZh : company.addressEn;
---

<!doctype html>
<html lang={language === "zh" ? "zh-CN" : "en"} data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <Seo title={title} description={description} pathname={pathname} language={language} alternates={alternates} jsonLd={jsonLd} />
    <script is:inline>
      let savedTheme = null;
      try {
        savedTheme = localStorage.getItem("theme");
      } catch {
        savedTheme = null;
      }
      const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
      document.documentElement.dataset.theme = savedTheme || (prefersDark ? "dark" : "light");
    </script>
  </head>
  <body>
    <div class="site-shell">
      <header class="site-toolbar" aria-label="Site controls">
        <a class="brand" href={localizePath(language)} aria-label={`${site.name} home`}>
          <span class="brand-mark" aria-hidden="true">
            <span></span>
            <span></span>
            <span></span>
          </span>
          <span class="brand-copy">
            <strong>{site.name}</strong>
            <small>{language === "zh" ? company.shortNameZh : company.shortNameEn}</small>
          </span>
        </a>
        <nav class="site-nav" aria-label="Primary">
          <a href={localizePath(language, "projects")}>{copy.projectLabel}</a>
          <a href={localizePath(language, "notes")}>{copy.noteLabel}</a>
          <a href={localizePath(language, "services")}>{copy.servicesLabel}</a>
          <a href={localizePath(language, "company")}>{copy.companyLabel}</a>
          <a href={localizePath(language, "about")}>{copy.aboutLabel}</a>
          <a class="nav-contact" href={localizePath(language, "contact")}>{copy.contactLabel}</a>
        </nav>
        <div class="control-stack">
          <a class="control-link" href={switchPath} hreflang={otherLanguage}>{copy.alternateLanguage}</a>
          <button type="button" class="control-button theme-toggle" data-theme-toggle aria-pressed="false" data-light-label={copy.themeLight} data-dark-label={copy.themeDark}>
            <span data-theme-label>{copy.themeDark}</span>
          </button>
        </div>
      </header>

      <main class="page-main">
        <slot />
      </main>

      <footer class="site-footer">
        <div class="footer-identity">
          <p>{site.author}</p>
          <strong>{companyName}</strong>
        </div>
        <div class="footer-details">
          <div>
            <span>{copy.footerContact}</span>
            <a href={company.phoneHref}>{company.phoneDisplay}</a>
          </div>
          <div>
            <span>{copy.footerOffice}</span>
            <p>{address}</p>
          </div>
        </div>
        <div class="footer-legal">
          <span>© {currentYear} {company.shortNameEn}</span>
          <a href={company.icpUrl} target="_blank" rel="noopener noreferrer">{company.icpNumber}</a>
        </div>
      </footer>
    </div>

    <script>
      const html = document.documentElement;
      const themeToggle = document.querySelector("[data-theme-toggle]");
      const themeLabel = document.querySelector("[data-theme-label]");

      function writePreference(key: string, value: string) {
        try {
          localStorage.setItem(key, value);
        } catch {
          return;
        }
      }

      function updateThemeLabel() {
        const isDark = html.dataset.theme === "dark";
        if (themeLabel && themeToggle instanceof HTMLElement) {
          themeLabel.textContent = isDark ? themeToggle.dataset.lightLabel || "Light" : themeToggle.dataset.darkLabel || "Dark";
        }
        themeToggle?.setAttribute("aria-pressed", String(isDark));
      }

      themeToggle?.addEventListener("click", () => {
        const nextTheme = html.dataset.theme === "dark" ? "light" : "dark";
        html.dataset.theme = nextTheme;
        writePreference("theme", nextTheme);
        updateThemeLabel();
      });

      updateThemeLabel();
    </script>
  </body>
</html>
