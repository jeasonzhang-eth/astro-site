---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { labels, localizePath, notes, site, type Language } from "../../../data/site";

export function getStaticPaths() {
  return site.languages.flatMap((lang) =>
    notes.map((note) => ({
      params: { lang, slug: note.slug },
      props: { note },
    })),
  );
}

const language = Astro.params.lang as Language;
const { note } = Astro.props;
const copy = labels[language];
const item = note[language];
const pathname = localizePath(language, `notes/${note.slug}`);
const alternatePath = localizePath(language === "en" ? "zh" : "en", `notes/${note.slug}`);
const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    headline: item.title,
    description: item.summary,
    author: {
      "@type": "Person",
      name: site.author,
    },
    inLanguage: language === "zh" ? "zh-CN" : "en",
    url: `${site.url}${pathname}`,
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: item.faq.map((entry) => ({
      "@type": "Question",
      name: entry.question,
      acceptedAnswer: {
        "@type": "Answer",
        text: entry.answer,
      },
    })),
  },
];
---

<BaseLayout title={item.title} description={item.summary} pathname={pathname} language={language} alternatePath={alternatePath} jsonLd={jsonLd}>
  <article class="content-page">
    <p class="eyebrow">{copy.noteLabel} / {item.tag}</p>
    <h1>{item.title}</h1>
    <p class="lede">{item.summary}</p>

    <div class="content-grid">
      <section>
        <h2>{copy.definition}</h2>
        <p>{item.definition}</p>
      </section>
      <section>
        <h2>{copy.overview}</h2>
        <p>{item.overview}</p>
      </section>
      <section>
        <h2>{copy.principles}</h2>
        <ul class="content-list">
          {item.principles.map((principle) => <li>{principle}</li>)}
        </ul>
      </section>
      <section>
        <h2>{copy.checklist}</h2>
        <ol class="content-list ordered">
          {item.checklist.map((item) => <li>{item}</li>)}
        </ol>
      </section>
      <section>
        <h2>{copy.examples}</h2>
        <ul class="content-list">
          {item.examples.map((example) => <li>{example}</li>)}
        </ul>
      </section>
      <section>
        <h2>{copy.nextSteps}</h2>
        <p>{item.next}</p>
      </section>
      <section>
        <h2>{copy.faq}</h2>
        <div class="faq-list">
          {item.faq.map((entry) => (
            <details>
              <summary>{entry.question}</summary>
              <p>{entry.answer}</p>
            </details>
          ))}
        </div>
      </section>
    </div>
  </article>
</BaseLayout>
