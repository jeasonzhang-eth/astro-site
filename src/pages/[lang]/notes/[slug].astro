---
import PortableNoteBody from "../../../components/notes/PortableNoteBody.astro";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import type { Language } from "../../../lib/site/language";
import { localizePath } from "../../../lib/site/routes";
import { getSiteContent } from "../../../lib/sanity/site-content";
import { getAllPublishedNotes, pairNotes, portableTextToPlainText } from "../../../lib/sanity/notes";
import type { SanityNote } from "../../../lib/sanity/types";

type Props = {
  note: SanityNote;
  alternate?: SanityNote;
};

export async function getStaticPaths() {
  const notes = await getAllPublishedNotes();
  const pairs = pairNotes(notes);

  return notes.map((note) => ({
    params: { lang: note.language, slug: note.slug },
    props: {
      note,
      alternate: pairs.get(note.translationKey)?.[note.language === "en" ? "zh" : "en"],
    },
  }));
}

const { labels, site } = await getSiteContent();
const { note, alternate } = Astro.props as Props;
const language = note.language as Language;
const copy = labels[language];
const pathname = localizePath(language, `notes/${note.slug}`);
const alternatePath = alternate
  ? localizePath(alternate.language as Language, `notes/${alternate.slug}`)
  : undefined;
const alternateSeoPath = alternate && alternate.seo?.noIndex !== true ? alternatePath : null;
const title = note.seo?.title || note.title;
const description = note.seo?.description || note.summary;
const tag = note.tags[0] || copy.noteLabel;
const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    headline: note.title,
    description,
    articleBody: portableTextToPlainText(note.content),
    author: {
      "@type": "Person",
      name: site.author,
    },
    inLanguage: language === "zh" ? "zh-CN" : "en",
    url: `${site.url}${pathname}`,
    datePublished: note.publishedAt,
    dateModified: note.updatedAt || note.publishedAt,
    keywords: note.seo?.keywords,
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: note.faq.map((entry) => ({
      "@type": "Question",
      name: entry.question,
      acceptedAnswer: {
        "@type": "Answer",
        text: portableTextToPlainText(entry.answer),
      },
    })),
  },
];
---

<BaseLayout
  title={title}
  description={description}
  pathname={pathname}
  language={language}
  alternatePath={alternatePath}
  alternateSeoPath={alternateSeoPath}
  noIndex={note.seo?.noIndex}
  jsonLd={jsonLd}
>
  <article class="content-page">
    <p class="eyebrow breadcrumb"><a href={localizePath(language, "notes")}>{copy.noteLabel}</a> / {tag}</p>
    <h1>{note.title}</h1>
    <p class="lede">{note.summary}</p>

    <div class="content-grid">
      <PortableNoteBody value={note.content} />
      <section>
        <h2>{copy.faq}</h2>
        <div class="faq-list">
          {note.faq.map((entry) => (
            <details>
              <summary>{entry.question}</summary>
              <PortableNoteBody value={entry.answer} />
            </details>
          ))}
        </div>
      </section>
    </div>
  </article>
</BaseLayout>
