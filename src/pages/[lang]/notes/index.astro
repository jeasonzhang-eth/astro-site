---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { labels, localizePath, site, type Language } from "../../../data/site";
import { getAllPublishedNotes } from "../../../lib/sanity/notes";
import type { SanityNote } from "../../../lib/sanity/types";

export async function getStaticPaths() {
  const notes = await getAllPublishedNotes();
  return site.languages.map((lang) => ({ params: { lang }, props: { notes } }));
}

const language = Astro.params.lang as Language;
const { notes } = Astro.props as { notes: SanityNote[] };
const languageNotes = notes.filter((note) => note.language === language);
const copy = labels[language];
const pathname = localizePath(language, "notes");
const alternatePath = localizePath(language === "en" ? "zh" : "en", "notes");
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: copy.allNotesTitle,
  description: copy.allNotesDescription,
  inLanguage: language === "zh" ? "zh-CN" : "en",
  url: `${site.url}${pathname}`,
};
---

<BaseLayout title={copy.allNotesTitle} description={copy.allNotesDescription} pathname={pathname} language={language} alternatePath={alternatePath} jsonLd={jsonLd}>
  <section class="content-page collection-page" aria-labelledby="notes-title">
    <p class="eyebrow">{copy.noteLabel}</p>
    <h1 id="notes-title">{copy.allNotesTitle}</h1>
    <p class="lede">{copy.allNotesDescription}</p>

    <div class="directory-list">
      {languageNotes.map((note) => (
        <a class="directory-card" href={localizePath(language, `notes/${note.slug}`)}>
          <p>{note.tags[0] || copy.noteLabel}</p>
          <h2>{note.title}</h2>
          <span>{note.summary}</span>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
