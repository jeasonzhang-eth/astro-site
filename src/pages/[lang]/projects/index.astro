---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { labels, localizePath, projects, site, type Language } from "../../../data/site";

export function getStaticPaths() {
  return site.languages.map((lang) => ({ params: { lang } }));
}

const language = Astro.params.lang as Language;
const copy = labels[language];
const pathname = localizePath(language, "projects");
const alternatePath = localizePath(language === "en" ? "zh" : "en", "projects");
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: copy.allProjectsTitle,
  description: copy.allProjectsDescription,
  inLanguage: language === "zh" ? "zh-CN" : "en",
  url: `${site.url}${pathname}`,
};
---

<BaseLayout title={copy.allProjectsTitle} description={copy.allProjectsDescription} pathname={pathname} language={language} alternatePath={alternatePath} jsonLd={jsonLd}>
  <section class="content-page collection-page" aria-labelledby="projects-title">
    <p class="eyebrow">{copy.projectLabel}</p>
    <h1 id="projects-title">{copy.allProjectsTitle}</h1>
    <p class="lede">{copy.allProjectsDescription}</p>

    <div class="directory-list">
      {projects.map((project) => {
        const item = project[language];
        return (
          <a class="directory-card" href={localizePath(language, `projects/${project.slug}`)}>
            <p>{item.kind}</p>
            <h2>{item.title}</h2>
            <span>{item.summary}</span>
          </a>
        );
      })}
    </div>
  </section>
</BaseLayout>
