---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { alternateLanguage, type Language } from "../../../lib/site/language";
import { localizePath } from "../../../lib/site/routes";
import { getSiteContent } from "../../../lib/sanity/site-content";

export async function getStaticPaths() {
  const { site } = await getSiteContent();
  return site.languages.map((lang) => ({ params: { lang } }));
}

const { projects, projectsPages, site } = await getSiteContent();
const language = Astro.params.lang as Language;
const page = projectsPages[language];
const pathname = localizePath(language, "projects");
const alternatePath = localizePath(alternateLanguage(language), "projects");
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: page.title,
  description: page.description,
  inLanguage: language === "zh" ? "zh-CN" : "en",
  url: `${site.url}${pathname}`,
};
---

<BaseLayout title={page.title} description={page.description} pathname={pathname} language={language} alternatePath={alternatePath} jsonLd={jsonLd}>
  <section class="content-page collection-page" aria-labelledby="projects-title">
    <p class="eyebrow">{page.eyebrow}</p>
    <h1 id="projects-title">{page.title}</h1>
    <p class="lede">{page.description}</p>

    <div class="directory-list">
      {projects.map((project) => {
        const item = project[language];
        return (
          <a class="directory-card" href={localizePath(language, `projects/${item.slug}`)}>
            <p>{item.kind}</p>
            <h2>{item.title}</h2>
            <span>{item.summary}</span>
          </a>
        );
      })}
    </div>
  </section>
</BaseLayout>
