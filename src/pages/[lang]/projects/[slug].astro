---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { alternateLanguage, SUPPORTED_LANGUAGES, type Language } from "../../../lib/site/language";
import { localizePath } from "../../../lib/site/routes";
import { getSiteContent, type LocalizedPair, type Project } from "../../../lib/sanity/site-content";

export async function getStaticPaths() {
  const { projects } = await getSiteContent();
  return projects.flatMap((project) =>
    SUPPORTED_LANGUAGES.map((lang) => ({
      params: { lang, slug: project[lang].slug },
      props: { project },
    })),
  );
}

const { labels, site } = await getSiteContent();
const language = Astro.params.lang as Language;
const { project } = Astro.props as { project: LocalizedPair<Project> };
const copy = labels[language];
const item = project[language];
const pathname = localizePath(language, `projects/${item.slug}`);
const otherLanguage = alternateLanguage(language);
const alternatePath = localizePath(otherLanguage, `projects/${project[otherLanguage].slug}`);
const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "CreativeWork",
    name: item.title,
    headline: item.title,
    description: item.summary,
    author: {
      "@type": "Person",
      name: site.author,
    },
    inLanguage: language === "zh" ? "zh-CN" : "en",
    url: `${site.url}${pathname}`,
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: item.faq.map((entry) => ({
      "@type": "Question",
      name: entry.question,
      acceptedAnswer: {
        "@type": "Answer",
        text: entry.answer,
      },
    })),
  },
];
---

<BaseLayout title={item.title} description={item.summary} pathname={pathname} language={language} alternatePath={alternatePath} jsonLd={jsonLd}>
  <article class="content-page">
    <p class="eyebrow breadcrumb"><a href={localizePath(language, "projects")}>{copy.projectLabel}</a> / {item.kind}</p>
    <h1>{item.title}</h1>
    <p class="lede">{item.summary}</p>

    <div class="content-grid">
      <section>
        <h2>{copy.definition}</h2>
        <p>{item.definition}</p>
      </section>
      <section>
        <h2>{copy.bestFor}</h2>
        <p>{item.audience}</p>
      </section>
      <section>
        <h2>{copy.overview}</h2>
        <p>{item.overview}</p>
      </section>
      <section>
        <h2>{copy.whyItMatters}</h2>
        <p>{item.why}</p>
      </section>
      <section>
        <h2>{copy.outcomes}</h2>
        <ul class="content-list">
          {item.outcomes.map((outcome) => <li>{outcome}</li>)}
        </ul>
      </section>
      <section>
        <h2>{copy.workflow}</h2>
        <ol class="content-list ordered">
          {item.workflow.map((step) => <li>{step}</li>)}
        </ol>
      </section>
      <section>
        <h2>{copy.nextSteps}</h2>
        <p>{item.next}</p>
      </section>
      <section>
        <h2>{copy.faq}</h2>
        <div class="faq-list">
          {item.faq.map((entry) => (
            <details>
              <summary>{entry.question}</summary>
              <p>{entry.answer}</p>
            </details>
          ))}
        </div>
      </section>
    </div>
  </article>
</BaseLayout>
