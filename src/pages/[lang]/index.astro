---
import EditorialArtwork from "../../components/EditorialArtwork.astro";
import DisplayHeadline from "../../components/DisplayHeadline.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { alternateLanguage, type Language } from "../../lib/site/language";
import { localizePath } from "../../lib/site/routes";
import { getSiteContent } from "../../lib/sanity/site-content";
import { getAllPublishedNotes } from "../../lib/sanity/notes";
import type { SanityNote } from "../../lib/sanity/types";

export async function getStaticPaths() {
  const [{ site }, notes] = await Promise.all([getSiteContent(), getAllPublishedNotes()]);
  return site.languages.map((lang) => ({ params: { lang }, props: { notes } }));
}

const { company, home, labels, projects, services, settings, site } = await getSiteContent();
const language = Astro.params.lang as Language;
const { notes } = Astro.props as { notes: SanityNote[] };
const languageNotes = notes.filter((note) => note.language === language);
const headlineLines = home[language].headlineLines;
const headlineLabel = home[language].headline;
const copy = labels[language];
const page = home[language];
const pathname = localizePath(language);
const alternatePath = localizePath(alternateLanguage(language));
const organizationName = language === "zh" ? company.legalNameZh : company.legalNameEn;
const organizationUrl = `${site.url}${localizePath(language, "company")}`;
const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Person",
    name: site.author,
    url: `${site.url}${localizePath(language, "about")}`,
    sameAs: [settings.githubUrl],
    founder: {
      "@type": "Organization",
      name: organizationName,
      url: organizationUrl,
    },
    worksFor: {
      "@type": "Organization",
      name: organizationName,
      url: organizationUrl,
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    name: organizationName,
    alternateName: language === "zh" ? company.shortNameEn : company.shortNameZh,
    url: organizationUrl,
    founder: {
      "@type": "Person",
      name: site.author,
      url: `${site.url}${localizePath(language, "about")}`,
    },
    telephone: company.phoneDisplay,
    address: language === "zh" ? company.addressZh : company.addressEn,
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: `${site.name} × ${company.shortNameEn}`,
    url: site.url,
    inLanguage: language === "zh" ? "zh-CN" : "en",
    description: page.description,
  },
];
---

<BaseLayout title={page.title} description={page.description} pathname={pathname} language={language} alternatePath={alternatePath} jsonLd={jsonLd}>
  <section class="hero integrated-hero" aria-labelledby="hero-title">
    <div class="hero-copy">
      <p class="eyebrow">{page.eyebrow}</p>
      <DisplayHeadline id="hero-title" ariaLabel={headlineLabel} lines={headlineLines} variant="hero" language={language} />
      <p class="hero-identity">{page.identity}</p>
      <p class="lede">{page.lede}</p>
      <div class="hero-actions" aria-label={page.primaryActionsLabel}>
        <a class="button primary" href="#work">{copy.viewWork}</a>
        <a class="button secondary" href={localizePath(language, "contact")}>{copy.contactAction}</a>
      </div>
    </div>

    <EditorialArtwork
      variant="workbench"
      priority={true}
      alt={page.artworkAlt}
      caption={page.artworkCaption}
    />
  </section>

  <section class="section" id="work" aria-labelledby="work-title">
    <div class="section-heading">
      <p class="eyebrow">{copy.selectedWork}</p>
      <h2 id="work-title">{copy.projectsTitle}</h2>
    </div>
    <div class="project-list">
      {projects.map((project) => {
        const item = project[language];
        return (
          <a class="project-card project-link" href={localizePath(language, `projects/${item.slug}`)}>
            <div>
              <p>{item.kind}</p>
              <h3>{item.title}</h3>
            </div>
            <span>{item.summary}</span>
          </a>
        );
      })}
    </div>
  </section>

  <section class="home-services" aria-labelledby="services-title">
    <div class="section-heading">
      <p class="eyebrow">{copy.servicesLabel}</p>
      <h2 id="services-title">{page.servicesTitle}</h2>
      <p>{page.servicesIntro}</p>
    </div>
    <div class="home-service-grid">
      {services.map((service, index) => {
        const item = service[language];
        return (
          <a href={`${localizePath(language, "services")}#${item.slug}`} class="home-service-card">
            <span>{String(index + 1).padStart(2, "0")}</span>
            <h3>{item.title}</h3>
            <p>{item.summary}</p>
          </a>
        );
      })}
    </div>
  </section>

  <section class="method-section" aria-labelledby="method-title">
    <div class="section-heading">
      <p class="eyebrow">{page.methodEyebrow}</p>
      <h2 id="method-title">{page.methodTitle}</h2>
    </div>
    <ol class="method-list">
      {page.methodSteps.map((step, index) => (
        <li>
          <span>{String(index + 1).padStart(2, "0")}</span>
          <p>{step}</p>
        </li>
      ))}
    </ol>
  </section>

  <section class="section notes" id="notes" aria-labelledby="notes-title">
    <div class="section-heading">
      <p class="eyebrow">{copy.currentNotes}</p>
      <h2 id="notes-title">{copy.notesTitle}</h2>
    </div>
    <ul class="note-tags">
      {languageNotes.map((note) => (
        <li>
          <a href={localizePath(language, `notes/${note.slug}`)}>{note.tags[0] || copy.noteLabel}</a>
        </li>
      ))}
    </ul>
  </section>

  <section class="closing-panel home-company-panel">
    <p class="eyebrow">{page.companyEyebrow}</p>
    <h2>{page.companyTitle}</h2>
    <p>{page.companyText}</p>
    <div class="panel-actions">
      <a class="button primary" href={localizePath(language, "company")}>{copy.companyLabel}</a>
      <a class="button secondary" href={localizePath(language, "contact")}>{copy.contactAction}</a>
    </div>
  </section>
</BaseLayout>

<style>
  .integrated-hero {
    min-height: auto;
    grid-template-columns: minmax(0, 1.12fr) minmax(360px, 0.88fr);
    gap: clamp(42px, 5.5vw, 78px);
    align-items: start;
    padding: clamp(56px, 7vw, 88px) 0 clamp(72px, 8vw, 108px);
  }

  .hero-copy {
    min-width: 0;
  }

  .hero-copy .eyebrow {
    margin-bottom: 18px;
  }

  .hero-copy .hero-identity {
    margin-top: 24px;
  }

  .hero-copy .lede {
    max-width: 680px;
    margin-top: 24px;
  }

  .integrated-hero > :global(.editorial-art) {
    width: min(100%, 570px);
    margin-top: clamp(66px, 7vw, 96px);
    justify-self: end;
  }

  @media (max-width: 980px) {
    .integrated-hero {
      grid-template-columns: minmax(0, 1fr) minmax(320px, 0.78fr);
      gap: 38px;
    }

    .integrated-hero > :global(.editorial-art) {
      margin-top: 74px;
    }
  }

  @media (max-width: 820px) {
    .integrated-hero {
      grid-template-columns: 1fr;
      gap: 38px;
      padding: 44px 0 72px;
    }

    .integrated-hero > :global(.editorial-art) {
      width: 100%;
      margin-top: 4px;
      justify-self: stretch;
    }
  }
</style>
