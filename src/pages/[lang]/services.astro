---
import EditorialArtwork from "../../components/EditorialArtwork.astro";
import DisplayHeadline from "../../components/DisplayHeadline.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { alternateLanguage, type Language } from "../../lib/site/language";
import { localizePath } from "../../lib/site/routes";
import { getSiteContent } from "../../lib/sanity/site-content";

export async function getStaticPaths() {
  const { site } = await getSiteContent();
  return site.languages.map((lang) => ({ params: { lang } }));
}

const { company, services, servicesPages, site } = await getSiteContent();
const language = Astro.params.lang as Language;
const page = servicesPages[language];
const headlineLines = page.headlineLines;
const headlineLabel = page.headline;
const pathname = localizePath(language, "services");
const alternatePath = localizePath(alternateLanguage(language), "services");
const organizationName = language === "zh" ? company.legalNameZh : company.legalNameEn;
const jsonLd = services.map((service) => ({
  "@context": "https://schema.org",
  "@type": "Service",
  name: service[language].title,
  description: service[language].summary,
  url: `${site.url}${pathname}#${service[language].slug}`,
  provider: {
    "@type": "Organization",
    name: organizationName,
    url: `${site.url}${localizePath(language, "company")}`,
  },
  areaServed: company.countryCode,
}));
---

<BaseLayout title={page.title} description={page.description} pathname={pathname} language={language} alternatePath={alternatePath} jsonLd={jsonLd}>
  <article class="content-page service-page">
    <p class="eyebrow">{page.eyebrow}</p>
    <DisplayHeadline ariaLabel={headlineLabel} lines={headlineLines} language={language} />
    <p class="lede">{page.lede}</p>

    <EditorialArtwork
      variant="systems"
      alt={page.artworkAlt}
      caption={page.artworkCaption}
    />

    <nav class="service-index" aria-label={page.title}>
      {services.map((service, index) => (
        <a href={`#${service[language].slug}`}>
          <span>{String(index + 1).padStart(2, "0")}</span>
          {service[language].title}
        </a>
      ))}
    </nav>

    <div class="service-detail-list">
      {services.map((service, index) => {
        const item = service[language];
        return (
          <section class="service-detail" id={service[language].slug}>
            <div class="service-number" aria-hidden="true">{String(index + 1).padStart(2, "0")}</div>
            <div class="service-body">
              <h2>{item.title}</h2>
              <p class="service-summary">{item.summary}</p>
              <div class="service-facts">
                <section>
                  <h3>{page.bestForLabel}</h3>
                  <p>{item.bestFor}</p>
                </section>
                <section>
                  <h3>{page.deliverablesLabel}</h3>
                  <ul>
                    {item.deliverables.map((deliverable) => <li>{deliverable}</li>)}
                  </ul>
                </section>
                <section>
                  <h3>{page.processLabel}</h3>
                  <ol>
                    {item.process.map((step) => <li>{step}</li>)}
                  </ol>
                </section>
                <section>
                  <h3>{page.evidenceLabel}</h3>
                  <p>{item.evidence}</p>
                </section>
                <section>
                  <h3>{page.boundariesLabel}</h3>
                  <p>{item.boundaries}</p>
                </section>
              </div>
            </div>
          </section>
        );
      })}
    </div>

    <section class="closing-panel">
      <p class="eyebrow">{page.eyebrow}</p>
      <h2>{page.ctaTitle}</h2>
      <p>{page.ctaText}</p>
      <a class="button primary" href={localizePath(language, "contact")}>{page.ctaLabel}</a>
    </section>
  </article>
</BaseLayout>
