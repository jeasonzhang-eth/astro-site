---
import DisplayHeadline from "../../components/DisplayHeadline.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { alternateLanguage, type Language } from "../../lib/site/language";
import { localizePath } from "../../lib/site/routes";
import { getSiteContent } from "../../lib/sanity/site-content";

export async function getStaticPaths() {
  const { site } = await getSiteContent();
  return site.languages.map((lang) => ({ params: { lang } }));
}

const { about, company, settings, site } = await getSiteContent();
const language = Astro.params.lang as Language;
const page = about[language];
const headlineLines = page.headlineLines;
const headlineLabel = page.headline;
const pathname = localizePath(language, "about");
const alternatePath = localizePath(alternateLanguage(language), "about");
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: site.author,
  url: `${site.url}${pathname}`,
  description: page.description,
  sameAs: [settings.githubUrl],
  founder: {
    "@type": "Organization",
    name: language === "zh" ? company.legalNameZh : company.legalNameEn,
    url: `${site.url}${localizePath(language, "company")}`,
  },
  worksFor: {
    "@type": "Organization",
    name: language === "zh" ? company.legalNameZh : company.legalNameEn,
    url: `${site.url}${localizePath(language, "company")}`,
  },
};
---

<BaseLayout title={page.title} description={page.description} pathname={pathname} language={language} alternatePath={alternatePath} jsonLd={jsonLd}>
  <article class="content-page about-page">
    <p class="eyebrow">{page.eyebrow}</p>
    <DisplayHeadline ariaLabel={headlineLabel} lines={headlineLines} language={language} />
    <p class="lede">{page.lede}</p>

    <div class="about-panel" aria-label={page.title}>
      <div class="about-mark" aria-hidden="true">
        <span></span>
        <span></span>
        <span></span>
      </div>
      <div>
        <p>{site.author}</p>
        <span>{page.description}</span>
      </div>
    </div>

    <div class="content-grid">
      <section>
        <h2>{page.experienceTitle}</h2>
        <ul class="content-list">
          {page.experience.map((item) => <li>{item}</li>)}
        </ul>
      </section>
      <section>
        <h2>{page.focusTitle}</h2>
        <ul class="content-list">
          {page.focus.map((item) => <li>{item}</li>)}
        </ul>
      </section>
      <section>
        <h2>{page.workTitle}</h2>
        <ul class="content-list">
          {page.work.map((item) => <li>{item}</li>)}
        </ul>
      </section>
      <section>
        <h2>{page.contactTitle}</h2>
        <p>{page.contact}</p>
      </section>
    </div>
  </article>
</BaseLayout>
