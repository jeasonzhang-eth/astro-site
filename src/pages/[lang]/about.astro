---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { about, localizePath, site, type Language } from "../../data/site";

export function getStaticPaths() {
  return site.languages.map((lang) => ({ params: { lang } }));
}

const language = Astro.params.lang as Language;
const page = about[language];
const pathname = localizePath(language, "about");
const alternatePath = localizePath(language === "en" ? "zh" : "en", "about");
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: site.author,
  url: `${site.url}${pathname}`,
  description: page.description,
  sameAs: ["https://github.com/jeasonzhang-eth"],
  founder: {
    "@type": "Organization",
    name: language === "zh" ? "深圳市倍数引擎软件技术有限责任公司" : "Shenzhen Multiple Engine Software Technology Co., Ltd.",
    url: `${site.url}${localizePath(language, "company")}`,
  },
  worksFor: {
    "@type": "Organization",
    name: language === "zh" ? "深圳市倍数引擎软件技术有限责任公司" : "Shenzhen Multiple Engine Software Technology Co., Ltd.",
    url: `${site.url}${localizePath(language, "company")}`,
  },
};
---

<BaseLayout title={page.title} description={page.description} pathname={pathname} language={language} alternatePath={alternatePath} jsonLd={jsonLd}>
  <article class="content-page about-page">
    <p class="eyebrow">{page.eyebrow}</p>
    <h1>{page.headline}</h1>
    <p class="lede">{page.lede}</p>

    <div class="about-panel" aria-label={page.title}>
      <div class="about-mark" aria-hidden="true">
        <span></span>
        <span></span>
        <span></span>
      </div>
      <div>
        <p>{site.author}</p>
        <span>{page.description}</span>
      </div>
    </div>

    <div class="content-grid">
      <section>
        <h2>{page.experienceTitle}</h2>
        <ul class="content-list">
          {page.experience.map((item) => <li>{item}</li>)}
        </ul>
      </section>
      <section>
        <h2>{page.focusTitle}</h2>
        <ul class="content-list">
          {page.focus.map((item) => <li>{item}</li>)}
        </ul>
      </section>
      <section>
        <h2>{page.workTitle}</h2>
        <ul class="content-list">
          {page.work.map((item) => <li>{item}</li>)}
        </ul>
      </section>
      <section>
        <h2>{page.contactTitle}</h2>
        <p>{page.contact}</p>
      </section>
    </div>
  </article>
</BaseLayout>
