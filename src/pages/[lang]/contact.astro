---
import DisplayHeadline from "../../components/DisplayHeadline.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { alternateLanguage, type Language } from "../../lib/site/language";
import { localizePath } from "../../lib/site/routes";
import { getSiteContent } from "../../lib/sanity/site-content";

export async function getStaticPaths() {
  const { site } = await getSiteContent();
  return site.languages.map((lang) => ({ params: { lang } }));
}

const { company, contactPages, site } = await getSiteContent();
const language = Astro.params.lang as Language;
const page = contactPages[language];
const headlineLines = page.headlineLines;
const headlineLabel = page.headline;
const pathname = localizePath(language, "contact");
const alternatePath = localizePath(alternateLanguage(language), "contact");
const organizationName = language === "zh" ? company.legalNameZh : company.legalNameEn;
const address = language === "zh" ? company.addressZh : company.addressEn;
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  name: page.title,
  description: page.description,
  url: `${site.url}${pathname}`,
  about: {
    "@type": "Organization",
    name: organizationName,
    telephone: company.phoneDisplay,
    address,
  },
};
---

<BaseLayout title={page.title} description={page.description} pathname={pathname} language={language} alternatePath={alternatePath} jsonLd={jsonLd}>
  <article class="content-page contact-page">
    <p class="eyebrow">{page.eyebrow}</p>
    <DisplayHeadline ariaLabel={headlineLabel} lines={headlineLines} language={language} />
    <p class="lede">{page.lede}</p>

    <div class="contact-layout">
      <a class="contact-call" href={company.phoneHref}>
        <span class="contact-call__content">
          <span class="contact-call__label">{page.phoneLabel}</span>
          <strong>{company.phoneDisplay}</strong>
          <span class="contact-call__description">{page.callDescription}</span>
        </span>
        <span class="contact-cta">
          <span>{page.callAction}</span>
          <span aria-hidden="true">→</span>
        </span>
      </a>

      <dl class="contact-facts">
        <div>
          <dt>{page.companyLabel}</dt>
          <dd>{organizationName}</dd>
        </div>
        <div>
          <dt>{page.addressLabel}</dt>
          <dd>{address}</dd>
        </div>
        <div>
          <dt>{page.icpLabel}</dt>
          <dd><a href={company.icpUrl} target="_blank" rel="noopener noreferrer">{company.icpNumber}</a></dd>
        </div>
      </dl>
    </div>

    <section class="contact-context">
      <h2>{page.cooperationTitle}</h2>
      <p>{page.cooperationText}</p>
      <a class="text-link" href={localizePath(language, "services")}>{language === "zh" ? "查看服务范围" : "Review service scope"}</a>
    </section>
  </article>
</BaseLayout>
