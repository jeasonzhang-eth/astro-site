---
import EditorialArtwork from "../../components/EditorialArtwork.astro";
import DisplayHeadline from "../../components/DisplayHeadline.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { company, companyPages } from "../../data/company";
import { localizePath, site, type Language } from "../../data/site";

export function getStaticPaths() {
  return site.languages.map((lang) => ({ params: { lang } }));
}

const language = Astro.params.lang as Language;
const headlineLines = language === "zh"
  ? ["一家围绕真实问题", "和可检查交付建立的", "软件公司。"]
  : ["A small software company", "built around", "inspectable work."];
const headlineLabel = headlineLines.join(language === "zh" ? "" : " ");
const page = companyPages[language];
const pathname = localizePath(language, "company");
const alternatePath = localizePath(language === "en" ? "zh" : "en", "company");
const organizationName = language === "zh" ? company.legalNameZh : company.legalNameEn;
const address = language === "zh" ? company.addressZh : company.addressEn;
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: organizationName,
  alternateName: language === "zh" ? company.shortNameEn : company.shortNameZh,
  url: `${site.url}${pathname}`,
  founder: {
    "@type": "Person",
    name: site.author,
    url: `${site.url}${localizePath(language, "about")}`,
  },
  telephone: company.phoneDisplay,
  address: {
    "@type": "PostalAddress",
    streetAddress: address,
    addressLocality: language === "zh" ? "深圳" : "Shenzhen",
    addressCountry: "CN",
  },
  description: page.description,
};
---

<BaseLayout title={page.title} description={page.description} pathname={pathname} language={language} alternatePath={alternatePath} jsonLd={jsonLd}>
  <article class="content-page company-page">
    <p class="eyebrow">{page.eyebrow}</p>
    <DisplayHeadline ariaLabel={headlineLabel} lines={headlineLines} language={language} />
    <p class="lede">{page.lede}</p>

    <EditorialArtwork
      variant="company"
      alt={language === "zh" ? "深圳城市建筑、服务器和版本化交付层组成的工程场景" : "A Shenzhen engineering scene with modern buildings, servers, and versioned delivery layers"}
      caption={language === "zh" ? "深圳的工程现场与稳定交付路径" : "A Shenzhen engineering base with a stable delivery path"}
    />

    <div class="company-stamp" aria-label={organizationName}>
      <span aria-hidden="true">倍</span>
      <div>
        <strong>{organizationName}</strong>
        <p>{language === "zh" ? company.legalNameEn : company.legalNameZh}</p>
      </div>
    </div>

    <div class="content-grid company-content">
      <section>
        <h2>{page.relationshipTitle}</h2>
        <p>{page.relationship}</p>
      </section>
      <section>
        <h2>{page.fieldsTitle}</h2>
        <ul class="content-list">
          {page.fields.map((item) => <li>{item}</li>)}
        </ul>
      </section>
      <section>
        <h2>{page.principlesTitle}</h2>
        <ol class="content-list ordered">
          {page.principles.map((item) => <li>{item}</li>)}
        </ol>
      </section>
      <section>
        <h2>{page.missionTitle}</h2>
        <p>{page.mission}</p>
      </section>
    </div>

    <section class="closing-panel">
      <p class="eyebrow">{company.shortNameEn}</p>
      <h2>{page.ctaTitle}</h2>
      <p>{page.ctaText}</p>
      <a class="button primary" href={localizePath(language, "contact")}>{page.ctaLabel}</a>
    </section>
  </article>
</BaseLayout>
