---
import { getSiteContent } from "../lib/sanity/site-content";

const { company, labels, site } = await getSiteContent();
const target = `/${site.defaultLanguage}/`;
const copy = labels[site.defaultLanguage];
const pageTitle = `${site.name} × ${company.shortNameEn}`;
---

<!doctype html>
<html lang={site.defaultLanguage === "zh" ? "zh-CN" : "en"}>
  <head>
    <meta charset="UTF-8" />
    <meta name="robots" content="noindex" />

    <script is:inline define:vars={{ target }}>
      window.location.replace(target);
    </script>

    <noscript>
      <meta http-equiv="refresh" content={`0; url=${target}`} />
    </noscript>

    <link rel="canonical" href={target} />
    <title>{pageTitle}</title>

    <style>
      html,
      body {
        margin: 0;
        background: #f5f2e9;
      }

      body {
        visibility: hidden;
      }
    </style>

    <noscript>
      <style>
        body {
          visibility: visible;
          display: grid;
          min-height: 100vh;
          place-items: center;
          padding: 24px;
          box-sizing: border-box;
          color: #11212b;
          font-family: system-ui, sans-serif;
        }
      </style>
    </noscript>
  </head>
  <body>
    <noscript>
      <p>
        {copy.redirectMessage}
        <a href={target}>{copy.redirectLinkLabel}</a>。
      </p>
    </noscript>
  </body>
</html>
