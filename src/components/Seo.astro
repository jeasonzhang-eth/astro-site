---
import { canonicalUrl, site, type Language } from "../data/site";

interface Props {
  title: string;
  description: string;
  pathname: string;
  language: Language;
  alternates?: Partial<Record<Language, string>>;
  noIndex?: boolean;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const { title, description, pathname, language, alternates = {}, noIndex, jsonLd } = Astro.props;
const url = canonicalUrl(pathname);
const pageTitle = title === site.name ? title : `${title} | ${site.name}`;
const structuredData = Array.isArray(jsonLd) ? jsonLd : jsonLd ? [jsonLd] : [];
---

<title>{pageTitle}</title>
<meta name="description" content={description} />
{noIndex && <meta name="robots" content="noindex, nofollow" />}
<link rel="canonical" href={url} />
{Object.entries(alternates).map(([lang, path]) => <link rel="alternate" hreflang={lang} href={canonicalUrl(path)} />)}
{alternates[site.defaultLanguage] && <link rel="alternate" hreflang="x-default" href={canonicalUrl(alternates[site.defaultLanguage]!)} />}
<meta property="og:site_name" content={site.name} />
<meta property="og:title" content={pageTitle} />
<meta property="og:description" content={description} />
<meta property="og:url" content={url} />
<meta property="og:type" content="website" />
<meta property="og:locale" content={language === "zh" ? "zh_CN" : "en_US"} />
<meta name="twitter:card" content="summary" />
<meta name="twitter:title" content={pageTitle} />
<meta name="twitter:description" content={description} />
{structuredData.map((item) => <script is:inline type="application/ld+json" set:html={JSON.stringify(item)} />)}
