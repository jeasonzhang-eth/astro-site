---
import type { PortableTextCodeBlock as SanityCodeBlockNode } from "../../lib/sanity/types";

interface Props {
  node: SanityCodeBlockNode;
}

const { node } = Astro.props;
if (typeof node.code !== "string" || !node.code.trim()) {
  throw new Error("Sanity Portable Text codeBlock requires non-empty code");
}
---

<div class="sanity-code-block">
  {node.filename && <p class="sanity-code-filename">{node.filename}</p>}
  <pre><code class:list={[node.language && `language-${node.language}`]}>{node.code}</code></pre>
</div>
