---
interface Props {
  ariaLabel: string;
  lines: string[];
  id?: string;
  variant?: "hero" | "page";
  language?: "zh" | "en";
}

const {
  ariaLabel,
  lines,
  id,
  variant = "page",
  language = "zh",
} = Astro.props;
---

<h1
  id={id}
  class="display-headline"
  data-variant={variant}
  data-language={language}
  aria-label={ariaLabel}
>
  {lines.map((line) => <span class="headline-line" aria-hidden="true">{line}</span>)}
</h1>

<style>
  .display-headline {
    max-width: none;
    margin: 0;
    overflow-wrap: normal;
    word-break: normal;
    hyphens: none;
    font-family: Georgia, "Times New Roman", serif;
    font-size: clamp(3rem, 5.9vw, 5.25rem);
    line-height: 0.96;
    letter-spacing: -0.025em;
    text-wrap: balance;
  }

  .headline-line {
    display: block;
    overflow-wrap: normal;
    word-break: normal;
    hyphens: none;
  }

  .display-headline[data-language="zh"] .headline-line {
    white-space: nowrap;
  }

  .display-headline[data-variant="hero"][data-language="en"] {
    font-size: clamp(2.35rem, 2.75vw, 2.45rem);
    line-height: 0.98;
    letter-spacing: -0.035em;
  }

  .display-headline[data-variant="hero"][data-language="en"] .headline-line {
    white-space: nowrap;
  }

  .display-headline[data-variant="page"] {
    font-size: clamp(2.9rem, 6vw, 4.8rem);
    line-height: 0.98;
  }

  .display-headline[data-variant="page"][data-language="en"] {
    font-size: clamp(2.75rem, 5.25vw, 4.35rem);
    letter-spacing: -0.035em;
  }

  @media (max-width: 820px) {
    .display-headline[data-variant="hero"] {
      font-size: clamp(3rem, 12.6vw, 3.4rem);
      line-height: 0.98;
    }

    .display-headline[data-variant="hero"][data-language="en"] {
      font-size: clamp(1.5rem, 6.4vw, 1.6rem);
      line-height: 1;
    }

    .display-headline[data-variant="page"] {
      font-size: clamp(2.15rem, 9.2vw, 3rem);
      line-height: 1;
    }

    .display-headline[data-variant="page"][data-language="en"] {
      font-size: clamp(2.45rem, 10.8vw, 3rem);
    }
  }

  @media (max-width: 420px) {
    .display-headline[data-variant="page"][data-language="zh"] {
      font-size: clamp(2rem, 8.75vw, 2.3rem);
    }
  }
</style>
